 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Analysis of Program Input vs. Pulse Width\\n",
    "This notebook analyzes the relationship between the program input (`PROG_IN`) and the resulting pulse width (`PULSE_WIDTH`) from CSV files in the `archive/measurements` directory.\\n",
    "The analysis focuses on files where VCC is 5.0 and filters out failed measurements where `PULSE_WIDTH` is greater than 1."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import glob\n",
    "import matplotlib.pyplot as plt\n",
    "import os"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "files = [
    "archive/measurements/prog_20260109_142529.csv",
    "archive/measurements/prog_20260109_142846.csv",
    "archive/measurements/prog_20260109_143013.csv",
    "archive/measurements/prog_20260109_143114.csv",
    "archive/measurements/prog_20260109_143613.csv",
    "archive/measurements/prog_20260109_144041.csv",
    "archive/measurements/prog_20260109_144119.csv",
    "archive/measurements/prog_20260109_145716.csv",
    "archive/measurements/prog_20260109_145806.csv",
    "archive/measurements/prog_20260109_153514.csv",
    "archive/measurements/prog_20260109_153642.csv",
    "archive/measurements/prog_20260109_155021.csv",
    "archive/measurements/prog_20260109_155429.csv",
    "archive/measurements/prog_20260109_155522.csv",
    "archive/measurements/prog_20260109_155712.csv",
    "archive/measurements/prog_20260109_160013.csv",
    "archive/measurements/prog_20260109_160039.csv",
    "archive/measurements/prog_20260109_160246.csv",
    "archive/measurements/prog_20260109_160947.csv",
    "archive/measurements/prog_20260109_161022.csv",
    "archive/measurements/prog_20260109_162048.csv",
    "archive/measurements/prog_20260109_162355.csv"
]\n",
    "for f in files:\n",
    "    try:\n",
    "        df = pd.read_csv(f)\n",
    "\n",
    "        # Check if VCC is 5.0\n",
    "        if 'VCC' not in df.columns or df['VCC'].iloc[0] != 5.0:\n",
    "            continue\n",
    "\n",
    "        # Filter out failed measurements\n",
    "        df_filtered = df[df['PULSE_WIDTH'] <= 1].copy()\n",
    "\n",
    "        if df_filtered.empty:\n",
    "            continue\n",
    "\n",
    "        # Separate ERASE and PROGRAM modes\n",
    "        erase_df = df_filtered[df_filtered['MODE'] == 'ERASE']\n",
    "        program_df = df_filtered[df_filtered['MODE'] == 'PROGRAM']\n",
    "\n",
    "        if erase_df.empty and program_df.empty:\n",
    "            continue\n",
    "\n",
    "        plt.figure(figsize=(10, 6))\n",
    "\n",
    "        if not erase_df.empty:\n",
    "            plt.plot(erase_df['PROG_IN'], erase_df['PULSE_WIDTH'], 'o-', label='ERASE')\n",
    "\n",
    "        if not program_df.empty:\n",
    "            plt.plot(program_df['PROG_IN'], program_df['PULSE_WIDTH'], 'o-', label='PROGRAM')\n",
    "\n",
    "        plt.xlabel('PROG_IN')\n",
    "        plt.ylabel('PULSE_WIDTH')\n",
    "        plt.xscale('log')\n",
    "        plt.yscale('log')\n",
    "        plt.title(f'Analysis for {os.path.basename(f)}')\n",
    "        plt.axhline(y=0.01, color='r', linestyle='--', label='Saturation line (0.01)')\n",
    "        plt.legend()\n",
    "        plt.grid(True, which=\"both\", ls=\"--\")\n",
    "        plt.show()\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f'Could not process file {f}: {e}')"
   ]
  }
 ],
